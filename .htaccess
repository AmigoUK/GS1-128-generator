# Front controller
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /GS1-128-generator/

    # Allow real files (assets, downloads) to pass through
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else routes through index.php
    RewriteRule ^ index.php [L]
</IfModule>

# Block direct access to sensitive directories
RedirectMatch 403 ^/GS1-128-generator/(includes|storage|tests|vendor)/.*$
RedirectMatch 403 ^/GS1-128-generator/composer\.(json|lock)$

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
