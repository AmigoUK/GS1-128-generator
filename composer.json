{
    "name": "amigouk/gs1-128-generator",
    "description": "GS1-128 (EAN-128) barcode generator with guided wizard and bulk import.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "picqer/php-barcode-generator": "^3.0",
        "tecnickcom/tcpdf": "^6.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "files": [
            "includes/config.php",
            "includes/helpers.php",
            "includes/ai-definitions.php",
            "includes/validation.php",
            "includes/barcode-generator.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "GS1\\Tests\\": "tests/"
        }
    }
}
